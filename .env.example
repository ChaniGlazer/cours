# כתובת הדומיין שבו האתר ירוץ בפועל (ללא / בסוף)
SITE_URL=https://your-domain.co.il

# סיסמת הכניסה לעמוד הניהול (/admin) - בחרו סיסמה חזקה וייחודית
ADMIN_PASSWORD=change-me-now

# פרטי חיבור לסליקה של Invoice4U (Clearing API). מפתח ה-API נוצר בכניסה ל-
# private.invoice4u.co.il -> הגדרות (Settings) -> הגדרות חשבון -> API -> Generate
INVOICE4U_API_KEY=REDACTED-ROTATED-API-KEY

# קוד חברת הסליקה שמוגדרת בחשבון ה-Invoice4U שלכם (מספר קבוע):
# Meshulam=7, UPay=6, YaadSarig=12, Cardcom=15
INVOICE4U_CC_COMPANY=15

# שליחת מייל לאיפוס סיסמה (SMTP) - אופציונלי. בלעדיו, קישור האיפוס יודפס
# ללוג של השרת בלבד. עובד עם כל ספק SMTP, כולל Gmail (עם App Password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
